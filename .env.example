# Hostname in a Cloudflare zone on the account selected during Alchemy login.
EXECUTOR_HOSTNAME=executor.example.com

# First person allowed through Cloudflare Access.
EXECUTOR_ALLOWED_EMAIL=you@example.com

# Existing Zero Trust team domain.
ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com

# Optional: override the pinned Executor commit used by scripts/bootstrap.ts.
# EXECUTOR_REVISION=24bccd671205d7acbe78e46c507973b5d15a7808
